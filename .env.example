# =========================================================
# BLOCKCHAIN (Hardhat) — letakkan file ini sebagai blockchain/.env
# =========================================================

# RPC URL Sepolia Testnet. Bisa didapat gratis dari Alchemy (alchemy.com)
# atau Infura (infura.io) — buat akun, buat App baru dengan network Sepolia.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key

# Private key wallet deployer (TANPA prefix 0x).
# JANGAN PERNAH commit private key asli ke git / upload ke mana pun!
# Gunakan wallet "burner" khusus untuk testnet, bukan wallet pribadi utama.
PRIVATE_KEY=your-wallet-private-key-without-0x-prefix

# API key Etherscan, untuk verifikasi source code contract (opsional).
# Daftar gratis di etherscan.io -> My Profile -> API Keys.
ETHERSCAN_API_KEY=your-etherscan-api-key

# Alamat contract yang sudah dideploy, dipakai oleh scripts/addIssuer.js
# (untuk menambahkan wallet teman sekelompok sebagai Authorized Issuer).
CONTRACT_ADDRESS=0xYourDeployedContractAddress

# =========================================================
# FRONTEND (Vite) — letakkan file ini sebagai frontend/.env
# =========================================================

# Alamat contract CertificateNotary yang sudah berhasil dideploy ke Sepolia.
# Didapat dari output "npx hardhat run scripts/deploy.js --network sepolia".
VITE_CONTRACT_ADDRESS=0xYourDeployedContractAddress
# RPC publik untuk fitur Verifikasi Sertifikat tanpa perlu connect wallet (opsional).
# Default sudah memakai RPC publik gratis jika variabel ini dikosongkan.
VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# =========================================================
# IDENTITAS INSTITUSI (opsional) — ditampilkan di Certificate Card
# =========================================================

# Nama institusi yang tampil di header Certificate Card.
VITE_INSTITUTION_NAME=Universitas Islam Negeri Syarif Hidayatullah Jakarta

# Nama & jabatan pejabat penandatangan (opsional).
# JIKA DIKOSONGKAN, bagian tanda tangan TIDAK akan muncul di Certificate Card.
# Isi ini hanya jika Anda memang berwenang mencantumkan nama tersebut —
# aplikasi ini bisa diakses publik setelah di-deploy ke Vercel.
VITE_SIGNING_OFFICIAL_NAME=
VITE_SIGNING_OFFICIAL_TITLE=Pejabat Berwenang

# =========================================================
# IPFS / PINATA (opsional) — supaya Foto Mahasiswa persisten
# =========================================================

# JWT dari akun Pinata (gratis, pinata.cloud) — dipakai untuk mengupload
# foto mahasiswa (dalam bentuk terenkripsi AES) ke IPFS supaya tetap bisa
# dipulihkan saat verifikasi dari sesi/perangkat lain. Kalau dikosongkan,
# foto tetap bisa dipakai untuk PDF saat itu juga, hanya tidak persisten.
# Cara dapat: daftar di pinata.cloud (gratis) -> API Keys -> New Key ->
# centang akses "pinJSONToIPFS" -> copy JWT-nya ke sini.
VITE_PINATA_JWT=
